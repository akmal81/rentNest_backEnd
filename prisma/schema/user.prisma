model User {
    id        String       @id @default(uuid())
    name      String       @db.VarChar(255)
    email     String       @unique
    password  String       @db.Text
    status    ActiveStatus @default(ACTIVE)
    role      Role         @default(TENANT)
    createdAt DateTime     @default(now())
    updatedAt DateTime     @updatedAt

    profile Profile?

    @@index([email])
    @@map("users")
}
